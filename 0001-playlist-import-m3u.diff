+    // Parse a standard #EXTM3U playlist (as produced by downloadM3U above) into
+    // track objects. Only title/artist/duration/file_path are recoverable from
+    // the file — loadQueue()/appendToQueue() in player.js already fill in the
+    // rest (audio_url, cover_url, led_color, etc.) from file_path when missing.
+    function parseM3U(text) {
+      const tracks = [];
+      let pendingDuration = 0;
+      let pendingArtist   = '';
+      let pendingTitle    = '';
+      text.split(/\r?\n/).forEach(raw => {
+        const line = raw.trim();
+        if (!line) return;
+        if (line.startsWith('#EXTINF:')) {
+          const body     = line.slice('#EXTINF:'.length);
+          const commaIdx = body.indexOf(',');
+          const durPart  = commaIdx === -1 ? body : body.slice(0, commaIdx);
+          const label    = commaIdx === -1 ? '' : body.slice(commaIdx + 1).trim();
+          pendingDuration = parseInt(durPart, 10) || 0;
+          const sepIdx = label.indexOf(' - ');
+          if (sepIdx === -1) {
+            pendingArtist = '';
+            pendingTitle  = label;
+          } else {
+            pendingArtist = label.slice(0, sepIdx).trim();
+            pendingTitle  = label.slice(sepIdx + 3).trim();
+          }
+          return;
+        }
+        if (line.startsWith('#')) return; // #EXTM3U u otra directiva — ignorar
+        // Línea de ruta/URL de la pista
+        tracks.push({
+          title:     pendingTitle || line.split('/').pop(),
+          artist:    pendingArtist,
+          duration:  pendingDuration,
+          file_path: line,
+        });
+        pendingDuration = 0; pendingArtist = ''; pendingTitle = '';
+      });
+      return tracks;
+    }
+
+    function importM3U(event) {
+      const input = event.target;
+      const file  = input.files && input.files[0];
+      if (!file) return;
+      const reader = new FileReader();
+      reader.onload = () => {
+        input.value = ''; // permite volver a importar el mismo archivo
+        const tracks = parseM3U(String(reader.result || ''));
+        if (!tracks.length) {
+          alert('El archivo M3U no contiene pistas válidas.');
+          return;
+        }
+        // Sustituye cualquier playlist actual de la sesión por la importada
+        // (loadQueue reemplaza la cola por completo y dispara 'queueLoaded',
+        // que ya mantiene sincronizados userPlaylist y el panel).
+        if (window.loadQueue) window.loadQueue(tracks);
+        else { window.userPlaylist = tracks; renderPlaylist(); }
+        // Reproduce automáticamente desde el primer elemento
+        if (window.playTrack) window.playTrack(0);
+      };
+      reader.onerror = () => alert('No se pudo leer el archivo M3U.');
+      reader.readAsText(file);
+    }
+    window.importM3U = importM3U;
+
