+        if (normalizeEnabled) _ensureNormalizeGraph();
+        window.currentAudio = currentAudio;
+    }
+    _resumeAudioCtxIfNeeded();
+    currentAudio.play().catch(() => {});
+}
+window.primeAudioForGesture = primeAudioForGesture;
