diff --git a/static/style.css b/static/style.css
index eba85b6..8b76096 100755
--- a/static/style.css
+++ b/static/style.css
@@ -171,15 +171,15 @@ html { font-size: clamp(13px, 0.9vw, 16px); }
 .player-led { display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; color:var(--led-white); transition:color 0.4s, filter 0.4s; }
 
 /* viz row: disc + eq side by side */
-.player-viz-row { display:flex; align-items:center; gap:6px; }
-.player-visualizer { width:34px; height:34px; position:relative; flex-shrink:0; --led-current:var(--led-white); }
+.player-viz-row { display:flex; align-items:center; gap:8px; }
+.player-visualizer { width:44px; height:44px; position:relative; flex-shrink:0; --led-current:var(--led-white); }
 .player-visualizer.spinning .viz-disc { animation:spin 3s linear infinite; animation-play-state:paused; }
 @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
 .viz-disc { width:100%; height:100%; display:block; overflow:visible; }
 
 /* EQ bars in normal flow beside disc */
-.viz-eq { display:flex; gap:2px; align-items:flex-end; height:22px; padding-bottom:2px; }
-.eq-bar { width:3px; height:5px; background:var(--led-current,var(--accent)); border-radius:1px 1px 0 0; transform-origin:bottom; }
+.viz-eq { display:flex; gap:2px; align-items:flex-end; height:28px; padding-bottom:3px; }
+.eq-bar { width:4px; height:6px; background:var(--led-current,var(--accent)); border-radius:1px 1px 0 0; transform-origin:bottom; }
 .viz-eq.active .eq-bar:nth-child(1) { animation:eq 0.7s ease-in-out infinite alternate; }
 .viz-eq.active .eq-bar:nth-child(2) { animation:eq 0.5s ease-in-out 0.1s infinite alternate; }
 .viz-eq.active .eq-bar:nth-child(3) { animation:eq 0.9s ease-in-out 0.2s infinite alternate; }
@@ -188,7 +188,7 @@ html { font-size: clamp(13px, 0.9vw, 16px); }
 @keyframes eq { from{transform:scaleY(0.4)} to{transform:scaleY(3)} }
 
 /* Controls always rendered, always visible */
-.player-controls-wrap { display:flex; flex-direction:column; align-items:center; gap:0.15rem; width:100%; }
+.player-controls-wrap { display:flex; flex-direction:column; align-items:center; gap:0.3rem; width:100%; }
 .player-controls { display:flex; align-items:center; gap:0.5rem; }
 .control-btn { background:none; border:none; color:var(--text-secondary); font-size:1.1rem; cursor:pointer; width:2.3rem; height:2.3rem; display:flex; align-items:center; justify-content:center; border-radius:50%; transition:color 0.15s,background 0.15s; }
 .control-btn:hover { color:var(--text-primary); background:rgba(255,255,255,0.06); }
