diff --git a/static/style.css b/static/style.css
index 39e5160..cb76e55 100755
--- a/static/style.css
+++ b/static/style.css
@@ -1396,7 +1396,15 @@ input:checked + .toggle-track:before { transform:translateX(16px); }
   :root { --player-h: 148px; }
 
   /* ─── General layout ──────────────────────────────────────────────── */
-  .base-container { padding-bottom: var(--player-h); }
+  /* Red de seguridad: varias grillas del home (era-card, quality-grid, etc.)
+     usaban anchos fijos que no cabían en pantallas angostas y forzaban
+     scroll horizontal de toda la página (contenido cortado en el borde
+     derecho, visible en las capturas adjuntas). Los anchos fijos se
+     corrigen en home.html, pero se deja este overflow-x:hidden como red de
+     seguridad ante cualquier otro elemento que se nos escape. No afecta a
+     los scrollers horizontales intencionales (.recent-scroll, .alphabet-bar),
+     que ya declaran su propio overflow-x:auto. */
+  .base-container { padding-bottom: var(--player-h); overflow-x: hidden; }
   .main-content   { padding: 8px 8px 0; }
 
   /* ─── Header: auto-height, logo left + search/alphabet stacked right ── */
@@ -1420,6 +1428,14 @@ input:checked + .toggle-track:before { transform:translateX(16px); }
   .artist-albums-grid { grid-template-columns: repeat(auto-fill, minmax(145px,1fr)); gap: 9px; }
   .artist-list        { grid-template-columns: repeat(auto-fill, minmax(155px,1fr)); }
 
+  /* ─── Home: stats bar ────────────────────────────────────────────── */
+  /* Antes: flex-wrap con 5 tarjetas de padding grande dejaba 3-4 arriba y
+     la última (TB) sola y centrada en su propia fila. Con grid parejo
+     todas quedan del mismo tamaño y se acomodan en 2-3 columnas. */
+  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px,1fr)); gap: 8px; }
+  .stat-card  { padding: 0.7rem 0.5rem; min-width: 0; }
+  .stat-value { font-size: 1.35rem; }
+
   /* ─── Album page ─────────────────────────────────────────────────── */
   .album-page       { flex-direction: column; gap: 12px; }
   .album-page-left  { width: 100%; align-items: center; }
@@ -1516,22 +1532,25 @@ input:checked + .toggle-track:before { transform:translateX(16px); }
     display: flex !important;
     flex-direction: row !important;
     align-items: center !important;
-    gap: 4px !important;
+    gap: 2px !important;
     flex-shrink: 0 !important;
     height: 100% !important;
   }
   .player-right .icon-btn {
-    width: 34px !important; height: 34px !important;
-    font-size: 0.92rem !important; padding: 0 !important;
+    width: 30px !important; height: 30px !important;
+    font-size: 0.88rem !important; padding: 0 !important;
     display: flex !important; align-items: center !important;
     justify-content: center !important; border-radius: 50% !important;
     flex-shrink: 0 !important;
   }
-  .icon-btn.fav-btn { width: 34px !important; height: 34px !important; font-size: 1.05rem !important; }
+  .icon-btn.fav-btn { width: 30px !important; height: 30px !important; font-size: 1rem !important; }
   .volume-wrap  { gap: 2px !important; }
-  .vol-icon     { font-size: 0.78rem !important; }
-  .volume-slider { width: 36px !important; }
+  .vol-icon     { font-size: 0.75rem !important; }
+  .volume-slider { width: 28px !important; }
   .outputs-wrap { display: none !important; }
+  /* Ya accesible en el reproductor de pantalla completa (#np-normalize-btn);
+     en la barra angosta solo suma un ícono más sin espacio real para tocarlo. */
+  .player-right .normalize-toggle { display: none !important; }
   #lyrics-toggle-btn { display: flex !important; }
 
   /* ── Row 2: controls ─── */
@@ -1665,8 +1684,14 @@ input:checked + .toggle-track:before { transform:translateX(16px); }
   .volume-slider { width: 60px; }
   .outputs-btn-label { display: none; }
   .album-grid { grid-template-columns: repeat(auto-fill, minmax(160px,1fr)); }
+}
 
 /* ── iOS safe area ────────────────────────────────────────────────────────── */
+/* BUGFIX: este bloque vivía anidado dentro del @media 769–1024px de arriba
+   (faltaba el "}" que ahora se agregó), por lo que la condición efectiva era
+   "769–1024px Y ≤768px" — imposible de cumplir. El padding para el home
+   indicator de iOS nunca se aplicaba en el player. Se saca como bloque
+   independiente para que sí aplique en ≤768px. */
 @supports (padding-bottom: env(safe-area-inset-bottom)) {
   @media (max-width: 768px) {
     .player-bar { padding-bottom: max(7px, calc(7px + env(safe-area-inset-bottom) * 0.5)) !important; }
